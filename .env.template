# Copy to .env and uncomment / edit as needed. The proxy auto-loads .env on
# startup (see src/claude_redact/__init__.py). .env is gitignored.

# --- Logging ---------------------------------------------------------------

# INFO (default) prints request counts and entity match summaries.
# DEBUG additionally logs request/response headers (api keys redacted) and
# the proxy's protocol-level control flow. Safe to set when sharing output —
# plaintext mask/unmask pairs are gated separately (CLAUDE_REDACT_LOG_VALUES).
# CLAUDE_REDACT_LOG_LEVEL=INFO

# Enable the `claude_redact.values` logger which emits one DEBUG line per
# fake ↔ original-value pair as masking/unmasking happens. Off by default
# because this stream contains the secrets the proxy is supposed to hide —
# anywhere this log goes (journald, file, tmux scrollback) becomes as
# sensitive as the proxy's memory.
# CLAUDE_REDACT_LOG_VALUES=0

# --- Privacy ---------------------------------------------------------------

# Expose GET /_audit/mappings — a JSON dump of every fake→plaintext pair
# the proxy currently holds. Off by default; when on, the route returns
# 200 with the full map. Anyone who can reach the port can fetch this, so
# keep the bind on localhost. A WARNING is logged at startup if the bind is
# network-reachable while audit is enabled.
# CLAUDE_REDACT_AUDIT=0

# Seed the fake-generator RNG. When set (integer or arbitrary string), the
# proxy generates identical fakes for identical input sequences across
# restarts — useful for tests, recordings, and golden-file fixtures. Only
# affects the generators' private Random instance; the global `random` state
# is left alone. Leave unset in production: an attacker who learns the seed
# AND observes the order of secrets reaching the proxy can replay the RNG
# and recover the forward map.
# CLAUDE_REDACT_SEED=

# --- Server ----------------------------------------------------------------

# Bind address for `python -m claude_redact`. (When launching via
# `uvicorn claude_redact:app …`, use uvicorn's own --host / --port flags.)
# CLAUDE_REDACT_HOST=127.0.0.1
# CLAUDE_REDACT_PORT=8888

# Where to forward masked requests. Override to point at a mock, a regional
# endpoint, or another Anthropic-compatible deployment.
# CLAUDE_REDACT_UPSTREAM=https://api.anthropic.com
