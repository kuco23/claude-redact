# Copy to .env and uncomment / edit as needed. The proxy auto-loads .env on
# startup (see src/claude_proxy/__init__.py). .env is gitignored.

# --- Logging ---------------------------------------------------------------

# INFO (default) prints request counts and entity match summaries.
# DEBUG additionally logs request/response headers (api keys redacted)
# and every placeholder ↔ original-value pair as it's masked/unmasked.
# CLAUDE_PROXY_LOG_LEVEL=INFO

# --- Server ----------------------------------------------------------------

# Bind address for `python -m claude_proxy`. (When launching via
# `uvicorn claude_proxy:app …`, use uvicorn's own --host / --port flags.)
# CLAUDE_PROXY_HOST=127.0.0.1
# CLAUDE_PROXY_PORT=8888

# Where to forward masked requests. Override to point at a mock, a regional
# endpoint, or another Anthropic-compatible deployment.
# CLAUDE_PROXY_UPSTREAM=https://api.anthropic.com
