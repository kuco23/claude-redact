# Copy to .env and uncomment / edit as needed. The proxy auto-loads .env on
# startup (see src/claude_proxy/__init__.py). .env is gitignored.

# --- Logging ---------------------------------------------------------------

# INFO (default) prints request counts and entity match summaries.
# DEBUG additionally logs request/response headers (api keys redacted) and
# the proxy's protocol-level control flow. Safe to set when sharing output —
# plaintext mask/unmask pairs are gated separately (CLAUDE_PROXY_LOG_VALUES).
# CLAUDE_PROXY_LOG_LEVEL=INFO

# Enable the `claude_proxy.values` logger which emits one DEBUG line per
# placeholder ↔ original-value pair as masking/unmasking happens. Off by
# default because this stream contains the secrets the proxy is supposed to
# hide — anywhere this log goes (journald, file, tmux scrollback) becomes as
# sensitive as the proxy's memory.
# CLAUDE_PROXY_LOG_VALUES=0

# --- Privacy ---------------------------------------------------------------

# Opaque placeholders: drop the entity-type segment so Anthropic only ever
# sees `<<MASK:hex>>` instead of `<<MASK:API_KEY:hex>>` etc. Tighter info
# leakage at the cost of model coherence (the model loses the "kind of
# secret" cue and can't say things like "your API key").
# CLAUDE_PROXY_OPAQUE=0

# Expose GET /_audit/mappings — a JSON dump of every placeholder→plaintext
# pair the proxy currently holds. Off by default; when on, the route returns
# 200 with the full map. Anyone who can reach the port can fetch this, so
# keep the bind on localhost. A WARNING is logged at startup if the bind is
# network-reachable while audit is enabled.
# CLAUDE_PROXY_AUDIT=0

# --- Server ----------------------------------------------------------------

# Bind address for `python -m claude_proxy`. (When launching via
# `uvicorn claude_proxy:app …`, use uvicorn's own --host / --port flags.)
# CLAUDE_PROXY_HOST=127.0.0.1
# CLAUDE_PROXY_PORT=8888

# Where to forward masked requests. Override to point at a mock, a regional
# endpoint, or another Anthropic-compatible deployment.
# CLAUDE_PROXY_UPSTREAM=https://api.anthropic.com
